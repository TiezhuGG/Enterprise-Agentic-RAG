APP_ENV=production
APP_PORT=3000
BACKEND_PORT=3000
FRONTEND_PORT=3001
RUN_SEED=false

DATABASE_URL=postgresql://postgres:change-me-postgres-password@postgres:5432/enterprise_agentic_rag
REDIS_URL=redis://redis:6379
ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTICSEARCH_INDEX=enterprise-agentic-rag-chunks
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_ENABLE_FALLBACK=true
REDIS_MEMORY_TTL=86400
MEMORY_WINDOW_SIZE=10
MEM0_API_URL=http://host.docker.internal:8080
MEM0_API_KEY=change-me-mem0-api-key

NEO4J_URI=http://neo4j:7474
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=change-me-neo4j-password

MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=change-me-minio-access-key
MINIO_SECRET_KEY=change-me-minio-secret-key
MINIO_BUCKET=enterprise-agentic-rag
MULTIMODAL_MAX_FILE_SIZE_MB=25
MULTIMODAL_ALLOWED_MIME_TYPES=image/png,image/jpeg,image/webp,image/gif,audio/mpeg,audio/wav,audio/webm,audio/mp4,audio/ogg,video/mp4,video/webm,video/quicktime
OCR_PROVIDER=metadata
OCR_API_URL=
OCR_API_KEY=
OCR_MODEL=
ASR_PROVIDER=metadata
ASR_API_URL=
ASR_API_KEY=
ASR_MODEL=
VIDEO_PROVIDER=metadata
VIDEO_API_URL=
VIDEO_API_KEY=
VIDEO_MODEL=

JWT_SECRET=change-me-with-at-least-32-characters-secret
JWT_EXPIRES_IN=1h

EMBEDDING_API_URL=http://host.docker.internal:11434/v1/embeddings
EMBEDDING_API_KEY=change-me-embedding-api-key
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSION=768

RERANKER_API_URL=http://host.docker.internal:11434/v1/rerank
RERANKER_API_KEY=change-me-reranker-api-key
RERANKER_MODEL=bge-reranker-v2-m3

LLM_API_URL=http://host.docker.internal:11434/v1/chat/completions
LLM_API_KEY=change-me-llm-api-key
LLM_MODEL=qwen2.5
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1024

AGENT_MAX_ITERATIONS=8
AGENT_ENABLE_GRAPH=true
AGENT_ENABLE_MEMORY=true

NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

POSTGRES_DB=enterprise_agentic_rag
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-postgres-password
