      "retrieval": {
        "limit": 5,
        "vectorLimit": 10,
        "keywordLimit": 10,
        "maxContextTokens": 2000,
        "enableGraph": false
      }
    },
    {
      "id": "keyword-bm25-exact-term-hit",
      "query": "报销制度",
      "expectedCitationChunkIds": ["replace-with-keyword-hit-chunk-id"],
      "expectedCitationDocumentIds": ["replace-with-policy-document-id"],
      "retrieval": {
        "limit": 5,
        "vectorLimit": 10,
        "keywordLimit": 10,
        "maxContextTokens": 2000,
        "enableGraph": false
      }
    },
    {
      "id": "graph-context-participates",
