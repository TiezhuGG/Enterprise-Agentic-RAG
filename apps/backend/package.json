{
  "name": "@enterprise-agentic-rag/backend",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "build": "pnpm prisma:generate && node --max-old-space-size=4096 ./node_modules/@nestjs/cli/bin/nest.js build",
    "batch:smoke": "pnpm prisma:generate && ts-node src/modules/batch/run-batch-smoke.ts",
    "demo:ingest": "pnpm prisma:generate && ts-node src/modules/ingestion/run-demo-ingest.ts",
    "demo:reset": "pnpm prisma:generate && ts-node src/modules/ingestion/run-demo-seed.ts --reset --no-ingest",
    "demo:seed": "pnpm prisma:generate && ts-node src/modules/ingestion/run-demo-seed.ts",
    "demo:smoke": "pnpm prisma:generate && ts-node src/modules/ingestion/run-demo-smoke.ts",
    "dev": "pnpm prisma:generate && nest start --watch",
    "error:smoke": "ts-node src/common/errors/run-error-smoke.ts",
    "evaluation:run": "pnpm prisma:generate && ts-node src/modules/evaluation/run-evaluation.ts",
    "lint": "eslint src/**/*.ts",
    "ops:smoke": "pnpm prisma:generate && ts-node src/modules/ops/run-ops-smoke.ts",
    "prisma:deploy": "prisma migrate deploy --config prisma.config.ts",
    "prisma:generate": "prisma generate --config prisma.config.ts",
    "prisma:migrate": "prisma migrate dev --config prisma.config.ts",
    "prisma:seed": "prisma db seed --config prisma.config.ts",
    "prisma:validate": "prisma validate --config prisma.config.ts",
    "provider:smoke": "pnpm prisma:generate && ts-node src/infrastructure/observability/run-provider-smoke.ts",
    "search:reindex": "pnpm prisma:generate && ts-node src/infrastructure/search/run-reindex.ts",
    "start": "node dist/main.js",
    "typecheck": "pnpm prisma:generate && tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@langchain/core": "^1.2.1",
    "@langchain/langgraph": "^1.4.7",
    "@nestjs/common": "^11.1.3",
    "@nestjs/core": "^11.1.3",
    "@nestjs/jwt": "^11.0.2",
    "@nestjs/passport": "^11.0.5",
    "@nestjs/platform-express": "^11.1.3",
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "bcryptjs": "^3.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "dotenv": "^17.4.2",
    "mammoth": "^1.12.0",
    "minio": "^8.0.7",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pdf-parse": "^2.4.5",
    "pg": "^8.22.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@nestjs/cli": "^11.0.7",
    "@nestjs/schematics": "^11.0.5",
    "@types/node": "^22.15.30",
    "@types/passport": "^1.0.17",
    "@types/passport-jwt": "^4.0.1",
    "prisma": "^7.8.0",
    "ts-node": "^10.9.2"
  }
}
