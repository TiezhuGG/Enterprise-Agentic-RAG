generator client {
  provider     = "prisma-client"
  output       = "../src/infrastructure/prisma/generated"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum KnowledgeSpaceVisibility {
  PRIVATE
  INTERNAL
  PUBLIC
}

enum KnowledgeSpaceStatus {
  ACTIVE
  ARCHIVED
  DELETED
}

enum KnowledgeSpaceType {
  GENERAL
  DEPARTMENT
  PROJECT
  CUSTOMER
}

enum SpaceMemberRole {
  OWNER
  EDITOR
  VIEWER
}

enum DocumentType {
  PDF
  WORD
  TXT
  MARKDOWN
  IMAGE
  AUDIO
  VIDEO
}

enum DocumentStatus {
  CREATED
  PROCESSING
  READY
  FAILED
  ARCHIVED
}

enum ConversationStatus {
  ACTIVE
  DELETED
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum MultimodalAttachmentType {
  IMAGE
  AUDIO
  VIDEO
}

enum MultimodalAttachmentStatus {
  CREATED
  EXTRACTED
  FAILED
}

enum PipelineJobStatus {
  QUEUED
  RUNNING
  SUCCEEDED
  FAILED
  CANCELED
}

enum PipelineEventStatus {
  STARTED
  SUCCEEDED
  FAILED
  SKIPPED
}

enum ExecutionRunStatus {
  RUNNING
  SUCCEEDED
  FAILED
}

enum ExecutionTraceEventStatus {
  STARTED
  SUCCEEDED
  FAILED
  SKIPPED
}

enum EnterpriseStatus {
  ACTIVE
  DISABLED
}

model User {
  id                    String                 @id @default(cuid())
  email                 String                 @unique
  name                  String?
  passwordHash          String?                @map("password_hash")
  isActive              Boolean                @default(true) @map("is_active")
  tenantId              String?                @map("tenant_id")
  organizationId        String?                @map("organization_id")
  departmentId          String?                @map("department_id")
  createdAt             DateTime               @default(now()) @map("created_at")
  updatedAt             DateTime               @updatedAt @map("updated_at")
  conversations         Conversation[]
  createdDocuments      Document[]             @relation("DocumentCreator")
  createdDocumentVersions DocumentVersion[]     @relation("DocumentVersionCreator")
  department            Department?            @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  executionRuns         ExecutionRun[]
  executionTraceEvents  ExecutionTraceEvent[]
  multimodalAttachments MultimodalAttachment[]
  organization          Organization?          @relation(fields: [organizationId], references: [id], onDelete: SetNull)
  ownedSpaces           KnowledgeSpace[]       @relation("KnowledgeSpaceOwner")
  roles                 UserRole[]
  spaces                SpaceMember[]
  tenant                Tenant?                @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([organizationId])
  @@index([departmentId])
  @@map("users")
}

model Tenant {
  id             String           @id @default(cuid())
  code           String           @unique
  name           String
  status         EnterpriseStatus @default(ACTIVE)
  metadata       Json             @default("{}")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  departments    Department[]
  organizations  Organization[]
  spaces         KnowledgeSpace[]
  users          User[]

  @@index([status])
  @@map("tenants")
}

model Organization {
  id          String           @id @default(cuid())
  tenantId    String           @map("tenant_id")
  code        String
  name        String
  status      EnterpriseStatus @default(ACTIVE)
  metadata    Json             @default("{}")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  departments Department[]
  tenant      Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users       User[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([status])
  @@map("organizations")
}

model Department {
  id             String           @id @default(cuid())
  tenantId       String           @map("tenant_id")
  organizationId String           @map("organization_id")
  parentId       String?          @map("parent_id")
  code           String
  name           String
  status         EnterpriseStatus @default(ACTIVE)
  metadata       Json             @default("{}")
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")
  children       Department[]     @relation("DepartmentHierarchy")
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  parent         Department?      @relation("DepartmentHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  tenant         Tenant           @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  users          User[]

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([organizationId])
  @@index([parentId])
  @@index([status])
  @@map("departments")
}

model Role {
  id          String           @id @default(cuid())
  code        String           @unique
  name        String
  description String?
  isSystem    Boolean          @default(false) @map("is_system")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  users       UserRole[]
  permissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String           @id @default(cuid())
  code        String           @unique
  name        String
  description String?
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  roles       RolePermission[]

  @@map("permissions")
}

model UserRole {
  userId     String   @map("user_id")
  roleId     String   @map("role_id")
  assignedAt DateTime @default(now()) @map("assigned_at")
  role       Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String     @map("role_id")
  permissionId String     @map("permission_id")
  assignedAt   DateTime   @default(now()) @map("assigned_at")
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model KnowledgeSpace {
  id          String                   @id @default(cuid())
  name        String
  description String?
  visibility  KnowledgeSpaceVisibility @default(PRIVATE)
  type        KnowledgeSpaceType       @default(GENERAL)
  status      KnowledgeSpaceStatus     @default(ACTIVE)
  ownerId     String                   @map("owner_id")
  tenantId    String?                  @map("tenant_id")
  metadata    Json                     @default("{}")
  createdAt   DateTime                 @default(now()) @map("created_at")
  updatedAt   DateTime                 @updatedAt @map("updated_at")
  documents   Document[]
  categories  DocumentCategory[]
  members     SpaceMember[]
  owner       User                     @relation("KnowledgeSpaceOwner", fields: [ownerId], references: [id], onDelete: Restrict)
  pipelineJobs PipelineJob[]
  tags        DocumentTag[]
  tenant      Tenant?                  @relation(fields: [tenantId], references: [id], onDelete: SetNull)

  @@index([ownerId])
  @@index([tenantId])
  @@index([type])
  @@map("knowledge_spaces")
}

model SpaceMember {
  spaceId String          @map("space_id")
  userId  String          @map("user_id")
  role    SpaceMemberRole
  space   KnowledgeSpace  @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([spaceId, userId])
  @@index([userId])
  @@map("space_members")
}

model Document {
  id          String           @id @default(cuid())
  spaceId     String           @map("space_id")
  title       String
  description String?
  type        DocumentType
  status      DocumentStatus   @default(CREATED)
  accessScope Json             @default("{}") @map("access_scope")
  categoryId  String?          @map("category_id")
  storageKey  String?          @map("storage_key")
  mimeType    String?          @map("mime_type")
  size        Int?
  createdBy   String           @map("created_by")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  chunks      Chunk[]
  category    DocumentCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  content     DocumentContent?
  creator     User             @relation("DocumentCreator", fields: [createdBy], references: [id], onDelete: Restrict)
  tagAssignments DocumentTagAssignment[]
  versions    DocumentVersion[]
  pipelineJobs PipelineJob[]
  space       KnowledgeSpace   @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@index([spaceId])
  @@index([categoryId])
  @@index([createdBy])
  @@index([status])
  @@map("documents")
}

model DocumentCategory {
  id          String             @id @default(cuid())
  spaceId     String             @map("space_id")
  name        String
  description String?
  color       String?
  parentId    String?            @map("parent_id")
  metadata    Json               @default("{}")
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")
  children    DocumentCategory[] @relation("DocumentCategoryHierarchy")
  documents   Document[]
  parent      DocumentCategory?  @relation("DocumentCategoryHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  space       KnowledgeSpace     @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@unique([spaceId, name])
  @@index([spaceId])
  @@index([parentId])
  @@map("document_categories")
}

model DocumentTag {
  id          String                  @id @default(cuid())
  spaceId     String                  @map("space_id")
  name        String
  color       String?
  metadata    Json                    @default("{}")
  createdAt   DateTime                @default(now()) @map("created_at")
  updatedAt   DateTime                @updatedAt @map("updated_at")
  assignments DocumentTagAssignment[]
  space       KnowledgeSpace          @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@unique([spaceId, name])
  @@index([spaceId])
  @@map("document_tags")
}

model DocumentTagAssignment {
  documentId String      @map("document_id")
  tagId      String      @map("tag_id")
  assignedAt DateTime    @default(now()) @map("assigned_at")
  document   Document    @relation(fields: [documentId], references: [id], onDelete: Cascade)
  tag        DocumentTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([documentId, tagId])
  @@index([tagId])
  @@map("document_tag_assignments")
}

model DocumentVersion {
  id            String         @id @default(cuid())
  documentId    String         @map("document_id")
  versionNumber Int            @map("version_number")
  title         String
  description   String?
  type          DocumentType
  status        DocumentStatus @default(CREATED)
  storageKey    String?        @map("storage_key")
  mimeType      String?        @map("mime_type")
  size          Int?
  sourceHash    String?        @map("source_hash")
  contentHash   String?        @map("content_hash")
  isCurrent     Boolean        @default(false) @map("is_current")
  metadata      Json           @default("{}")
  createdBy     String         @map("created_by")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")
  creator       User           @relation("DocumentVersionCreator", fields: [createdBy], references: [id], onDelete: Restrict)
  document      Document       @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@unique([documentId, versionNumber])
  @@index([documentId, isCurrent])
  @@index([createdBy])
  @@index([status])
  @@map("document_versions")
}

model DocumentContent {
  id         String   @id @default(cuid())
  documentId String   @unique @map("document_id")
  content    String
  metadata   Json     @default("{}")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")
  document   Document @relation(fields: [documentId], references: [id], onDelete: Cascade)

  @@map("document_contents")
}

model Chunk {
  id         String          @id @default(cuid())
  documentId String          @map("document_id")
  content    String
  sequence   Int
  tokenCount Int             @map("token_count")
  metadata   Json
  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @updatedAt @map("updated_at")
  document   Document        @relation(fields: [documentId], references: [id], onDelete: Cascade)
  embedding  ChunkEmbedding?

  @@unique([documentId, sequence])
  @@index([documentId])
  @@map("chunks")
}

model ChunkEmbedding {
  id        String                @id @default(cuid())
  chunkId   String                @unique @map("chunk_id")
  model     String
  dimension Int
  vector    Unsupported("vector(768)")
  createdAt DateTime              @default(now()) @map("created_at")
  updatedAt DateTime              @updatedAt @map("updated_at")
  chunk     Chunk                 @relation(fields: [chunkId], references: [id], onDelete: Cascade)

  @@index([model])
  @@map("chunk_embeddings")
}

model PipelineJob {
  id          String            @id @default(cuid())
  documentId  String            @map("document_id")
  spaceId     String            @map("space_id")
  executionId String?           @map("execution_id")
  requestId   String?           @map("request_id")
  triggeredBy String?           @map("triggered_by")
  status      PipelineJobStatus @default(RUNNING)
  metadata    Json              @default("{}")
  startedAt   DateTime          @default(now()) @map("started_at")
  finishedAt  DateTime?         @map("finished_at")
  createdAt   DateTime          @default(now()) @map("created_at")
  updatedAt   DateTime          @updatedAt @map("updated_at")
  document    Document          @relation(fields: [documentId], references: [id], onDelete: Cascade)
  events      PipelineEvent[]
  space       KnowledgeSpace    @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@index([documentId, createdAt])
  @@index([spaceId, createdAt])
  @@index([executionId])
  @@index([status])
  @@map("pipeline_jobs")
}

model PipelineEvent {
  id           String              @id @default(cuid())
  jobId        String              @map("job_id")
  documentId   String              @map("document_id")
  spaceId      String              @map("space_id")
  stage        String
  status       PipelineEventStatus
  durationMs   Int?                @map("duration_ms")
  metadata     Json                @default("{}")
  errorMessage String?             @map("error_message")
  createdAt    DateTime            @default(now()) @map("created_at")
  job          PipelineJob         @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, createdAt])
  @@index([documentId, createdAt])
  @@index([spaceId, createdAt])
  @@index([stage, status])
  @@map("pipeline_events")
}

model Conversation {
  id                    String                 @id @default(cuid())
  title                 String
  status                ConversationStatus     @default(ACTIVE)
  userId                String                 @map("user_id")
  createdAt             DateTime               @default(now()) @map("created_at")
  updatedAt             DateTime               @updatedAt @map("updated_at")
  executionRuns         ExecutionRun[]
  messages              Message[]
  multimodalAttachments MultimodalAttachment[]
  user                  User                   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@map("conversations")
}

model Message {
  id             String       @id @default(cuid())
  conversationId String       @map("conversation_id")
  role           MessageRole
  content        String
  metadata       Json
  createdAt      DateTime     @default(now()) @map("created_at")
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@map("messages")
}

model MultimodalAttachment {
  id            String                     @id @default(cuid())
  userId        String                     @map("user_id")
  conversationId String?                   @map("conversation_id")
  type          MultimodalAttachmentType
  status        MultimodalAttachmentStatus @default(CREATED)
  filename      String
  mimeType      String                     @map("mime_type")
  size          Int
  storageKey    String                     @map("storage_key")
  extractedText String                     @map("extracted_text")
  metadata      Json                       @default("{}")
  createdAt     DateTime                   @default(now()) @map("created_at")
  updatedAt     DateTime                   @updatedAt @map("updated_at")
  conversation  Conversation?              @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  user          User                       @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([conversationId])
  @@index([status])
  @@map("multimodal_attachments")
}

model ExecutionRun {
  id             String                @id @default(cuid())
  executionId    String                @unique @map("execution_id")
  requestId      String                @map("request_id")
  userId         String                @map("user_id")
  conversationId String?               @map("conversation_id")
  source         String
  status         ExecutionRunStatus    @default(RUNNING)
  startedAt      DateTime              @default(now()) @map("started_at")
  completedAt    DateTime?             @map("completed_at")
  durationMs     Int?                  @map("duration_ms")
  metadata       Json                  @default("{}")
  createdAt      DateTime              @default(now()) @map("created_at")
  updatedAt      DateTime              @updatedAt @map("updated_at")
  conversation   Conversation?         @relation(fields: [conversationId], references: [id], onDelete: SetNull)
  events         ExecutionTraceEvent[]
  user           User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([conversationId, createdAt])
  @@index([requestId])
  @@index([status])
  @@map("execution_runs")
}

model ExecutionTraceEvent {
  id           String                    @id @default(cuid())
  executionId  String                    @map("execution_id")
  requestId    String                    @map("request_id")
  userId       String                    @map("user_id")
  type         String
  stage        String
  node         String?
  status       ExecutionTraceEventStatus
  durationMs   Int?                      @map("duration_ms")
  sequence     Int
  metadata     Json                      @default("{}")
  errorMessage String?                   @map("error_message")
  timestamp    DateTime                  @default(now())
  run          ExecutionRun              @relation(fields: [executionId], references: [executionId], onDelete: Cascade)
  user         User                      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([executionId, sequence])
  @@index([executionId, sequence])
  @@index([userId, timestamp])
  @@index([requestId])
  @@index([type, status])
  @@map("execution_trace_events")
}
