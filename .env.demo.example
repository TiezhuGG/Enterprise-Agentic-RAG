APP_ENV=production
APP_PORT=3000
PUBLIC_HTTP_PORT=80
CORS_ORIGINS=http://CHANGE_ME_SERVER_IP
RUN_SEED=false

GHCR_IMAGE_PREFIX=ghcr.io/change-me-owner/change-me-repository
IMAGE_TAG=latest

POSTGRES_DB=enterprise_agentic_rag
POSTGRES_USER=enterprise_rag
POSTGRES_PASSWORD=CHANGE_ME_POSTGRES_PASSWORD
DATABASE_URL=postgresql://enterprise_rag:CHANGE_ME_POSTGRES_PASSWORD@postgres:5432/enterprise_agentic_rag

REDIS_URL=redis://redis:6379
REDIS_MEMORY_TTL=86400
MEMORY_WINDOW_SIZE=10
MEM0_API_URL=http://127.0.0.1:65535
MEM0_API_KEY=disabled

ELASTICSEARCH_URL=http://elasticsearch:9200
ELASTICSEARCH_INDEX=enterprise-agentic-rag-chunks
ELASTICSEARCH_USERNAME=elastic
ELASTICSEARCH_PASSWORD=CHANGE_ME_ELASTICSEARCH_PASSWORD
ELASTICSEARCH_ENABLE_FALLBACK=true

NEO4J_URI=http://neo4j:7474
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=CHANGE_ME_NEO4J_PASSWORD

MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=CHANGE_ME_MINIO_ACCESS_KEY
MINIO_SECRET_KEY=CHANGE_ME_MINIO_SECRET_KEY
MINIO_BUCKET=enterprise-agentic-rag

MULTIMODAL_MAX_FILE_SIZE_MB=25
MULTIMODAL_ALLOWED_MIME_TYPES=image/png,image/jpeg,image/webp,image/gif,audio/mpeg,audio/wav,audio/webm,audio/mp4,audio/ogg,video/mp4,video/webm,video/quicktime
OCR_PROVIDER=metadata
OCR_API_URL=
OCR_API_KEY=
OCR_MODEL=
PDF_OCR_ENABLED=true
PDF_OCR_MAX_PAGES=20
PDF_OCR_RENDER_WIDTH=1400
PDF_OCR_MAX_IMAGE_DIMENSION=2048
PDF_OCR_CONCURRENCY=1
PDF_OCR_MIN_TEXT_LENGTH=30
ASR_PROVIDER=metadata
ASR_API_URL=
ASR_API_KEY=
ASR_MODEL=
VIDEO_PROVIDER=metadata
VIDEO_API_URL=
VIDEO_API_KEY=
VIDEO_MODEL=

JWT_SECRET=CHANGE_ME_AT_LEAST_32_CHARACTER_RANDOM_SECRET
JWT_EXPIRES_IN=1h

EMBEDDING_API_URL=http://ollama:11434/v1/embeddings
EMBEDDING_API_KEY=ollama
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSION=768

LLM_API_URL=CHANGE_ME_OPENAI_COMPATIBLE_CHAT_COMPLETIONS_URL
LLM_API_KEY=CHANGE_ME_LLM_API_KEY
LLM_MODEL=CHANGE_ME_LLM_MODEL
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=4096

RERANKER_API_URL=CHANGE_ME_RERANKER_URL
RERANKER_API_KEY=CHANGE_ME_RERANKER_API_KEY
RERANKER_MODEL=CHANGE_ME_RERANKER_MODEL

AGENT_MAX_ITERATIONS=6
AGENT_ENABLE_GRAPH=false
AGENT_ENABLE_MEMORY=false
INGESTION_WORKER_ENABLED=false

COST_CURRENCY=CNY
COST_LLM_INPUT_PER_1K=0
COST_LLM_OUTPUT_PER_1K=0
COST_EMBEDDING_PER_1K=0

NEXT_PUBLIC_API_BASE_URL=/api
