APP_ENV=local
APP_PORT=3000
CORS_ORIGINS=http://localhost:3001,http://127.0.0.1:3001
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/enterprise_agentic_rag
REDIS_URL=redis://localhost:6379
ELASTICSEARCH_URL=http://localhost:9200
ELASTICSEARCH_INDEX=enterprise-agentic-rag-chunks
ELASTICSEARCH_USERNAME=
ELASTICSEARCH_PASSWORD=
ELASTICSEARCH_ENABLE_FALLBACK=true
REDIS_MEMORY_TTL=86400
MEMORY_WINDOW_SIZE=10
MEM0_API_URL=http://localhost:8080
MEM0_API_KEY=local-mem0-key
NEO4J_URI=http://localhost:7474
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=neo4jpassword
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin123456
MINIO_BUCKET=enterprise-agentic-rag
MULTIMODAL_MAX_FILE_SIZE_MB=25
MULTIMODAL_ALLOWED_MIME_TYPES=image/png,image/jpeg,image/webp,image/gif,audio/mpeg,audio/wav,audio/webm,audio/mp4,audio/ogg,video/mp4,video/webm,video/quicktime
OCR_PROVIDER=metadata
OCR_API_URL=
OCR_API_KEY=
OCR_MODEL=
PDF_OCR_ENABLED=true
PDF_OCR_MAX_PAGES=20
PDF_OCR_RENDER_WIDTH=1400
PDF_OCR_MAX_IMAGE_DIMENSION=2048
PDF_OCR_CONCURRENCY=2
PDF_OCR_MIN_TEXT_LENGTH=30
ASR_PROVIDER=metadata
ASR_API_URL=
ASR_API_KEY=
ASR_MODEL=
VIDEO_PROVIDER=metadata
VIDEO_API_URL=
VIDEO_API_KEY=
VIDEO_MODEL=
JWT_SECRET=replace-with-at-least-32-characters-secret
JWT_EXPIRES_IN=1h
EMBEDDING_API_URL=http://localhost:11434/v1/embeddings
EMBEDDING_API_KEY=local-embedding-key
EMBEDDING_MODEL=nomic-embed-text
EMBEDDING_DIMENSION=768
RERANKER_API_URL=http://localhost:11434/v1/rerank
RERANKER_API_KEY=local-reranker-key
RERANKER_MODEL=bge-reranker-v2-m3
LLM_API_URL=http://localhost:11434/v1/chat/completions
LLM_API_KEY=local-llm-key
LLM_MODEL=qwen2.5
LLM_TEMPERATURE=0.2
LLM_MAX_TOKENS=1024
AGENT_MAX_ITERATIONS=8
AGENT_ENABLE_GRAPH=true
AGENT_ENABLE_MEMORY=true

NEXT_PUBLIC_API_BASE_URL=http://localhost:3000

POSTGRES_DB=enterprise_agentic_rag
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
