{
  "name": "enterprise-agentic-rag",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=20.11.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "build": "pnpm --workspace-concurrency=1 -r build",
    "demo:ingest": "pnpm --filter @enterprise-agentic-rag/backend demo:ingest",
    "demo:reset": "pnpm --filter @enterprise-agentic-rag/backend demo:reset",
    "demo:seed": "pnpm --filter @enterprise-agentic-rag/backend demo:seed",
    "demo:smoke": "pnpm --filter @enterprise-agentic-rag/backend demo:smoke",
    "dev": "pnpm --parallel --filter @enterprise-agentic-rag/backend --filter @enterprise-agentic-rag/frontend dev",
    "dev:backend": "pnpm --filter @enterprise-agentic-rag/backend dev",
    "dev:frontend": "pnpm --filter @enterprise-agentic-rag/frontend dev",
    "db:deploy": "pnpm --filter @enterprise-agentic-rag/backend prisma:deploy",
    "db:generate": "pnpm --filter @enterprise-agentic-rag/backend prisma:generate",
    "db:migrate": "pnpm --filter @enterprise-agentic-rag/backend prisma:migrate",
    "db:seed": "pnpm --filter @enterprise-agentic-rag/backend prisma:seed",
    "db:validate": "pnpm --filter @enterprise-agentic-rag/backend prisma:validate",
    "docker:down": "docker compose --env-file .env -f docker/docker-compose.yml down",
    "docker:prod:build": "docker compose --env-file .env.production -f docker/docker-compose.prod.yml build",
    "docker:prod:config": "docker compose --env-file .env.production -f docker/docker-compose.prod.yml config",
    "docker:prod:down": "docker compose --env-file .env.production -f docker/docker-compose.prod.yml down",
    "docker:prod:logs": "docker compose --env-file .env.production -f docker/docker-compose.prod.yml logs -f",
    "docker:prod:up": "docker compose --env-file .env.production -f docker/docker-compose.prod.yml up -d",
    "docker:up": "docker compose --env-file .env -f docker/docker-compose.yml up -d",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "prepare": "husky || exit 0",
    "provider:smoke": "pnpm --filter @enterprise-agentic-rag/backend provider:smoke",
    "search:reindex": "pnpm --filter @enterprise-agentic-rag/backend search:reindex",
    "typecheck": "pnpm --workspace-concurrency=1 -r typecheck"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.30.1",
    "@next/eslint-plugin-next": "^15.3.4",
    "eslint": "^9.30.1",
    "eslint-config-next": "^15.3.4",
    "eslint-config-prettier": "^10.1.5",
    "globals": "^16.2.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.1.2",
    "prettier": "^3.6.2",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.35.1"
  }
}
